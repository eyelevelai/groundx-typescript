{
    "name": "groundx",
    "version": "3.5.0",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eyelevelai/groundx-typescript.git"
    },
    "license": "MIT",
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./documents": {
            "import": {
                "types": "./dist/esm/api/resources/documents/exports.d.mts",
                "default": "./dist/esm/api/resources/documents/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/documents/exports.d.ts",
                "default": "./dist/cjs/api/resources/documents/exports.js"
            },
            "default": "./dist/cjs/api/resources/documents/exports.js"
        },
        "./search": {
            "import": {
                "types": "./dist/esm/api/resources/search/exports.d.mts",
                "default": "./dist/esm/api/resources/search/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/search/exports.d.ts",
                "default": "./dist/cjs/api/resources/search/exports.js"
            },
            "default": "./dist/cjs/api/resources/search/exports.js"
        },
        "./buckets": {
            "import": {
                "types": "./dist/esm/api/resources/buckets/exports.d.mts",
                "default": "./dist/esm/api/resources/buckets/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/buckets/exports.d.ts",
                "default": "./dist/cjs/api/resources/buckets/exports.js"
            },
            "default": "./dist/cjs/api/resources/buckets/exports.js"
        },
        "./groups": {
            "import": {
                "types": "./dist/esm/api/resources/groups/exports.d.mts",
                "default": "./dist/esm/api/resources/groups/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/groups/exports.d.ts",
                "default": "./dist/cjs/api/resources/groups/exports.js"
            },
            "default": "./dist/cjs/api/resources/groups/exports.js"
        },
        "./workflows": {
            "import": {
                "types": "./dist/esm/api/resources/workflows/exports.d.mts",
                "default": "./dist/esm/api/resources/workflows/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/workflows/exports.d.ts",
                "default": "./dist/cjs/api/resources/workflows/exports.js"
            },
            "default": "./dist/cjs/api/resources/workflows/exports.js"
        },
        "./customer": {
            "import": {
                "types": "./dist/esm/api/resources/customer/exports.d.mts",
                "default": "./dist/esm/api/resources/customer/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/customer/exports.d.ts",
                "default": "./dist/cjs/api/resources/customer/exports.js"
            },
            "default": "./dist/cjs/api/resources/customer/exports.js"
        },
        "./apiKey": {
            "import": {
                "types": "./dist/esm/api/resources/apiKey/exports.d.mts",
                "default": "./dist/esm/api/resources/apiKey/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/apiKey/exports.d.ts",
                "default": "./dist/cjs/api/resources/apiKey/exports.js"
            },
            "default": "./dist/cjs/api/resources/apiKey/exports.js"
        },
        "./health": {
            "import": {
                "types": "./dist/esm/api/resources/health/exports.d.mts",
                "default": "./dist/esm/api/resources/health/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/health/exports.d.ts",
                "default": "./dist/cjs/api/resources/health/exports.js"
            },
            "default": "./dist/cjs/api/resources/health/exports.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "biome format --write --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "format:check": "biome format --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint": "biome lint --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint:fix": "biome lint --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check": "biome check --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check:fix": "biome check --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {
        "url-join": ">=5.0.0"
    },
    "devDependencies": {
        "webpack": "^5.105.4",
        "ts-loader": "^9.5.4",
        "vitest": "^4.1.1",
        "msw": "2.11.2",
        "@types/node": "^18.19.70",
        "typescript": "~5.9.3",
        "@biomejs/biome": "2.4.10"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false
}
